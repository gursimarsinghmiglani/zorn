program ::= { declaration } EOF

declaration ::= var_decl 
              | const_decl
              | function_decl
              | extern_fn_decl

var_decl ::= LET ID ( COLON type [ ASSIGN expr ] | ASSIGN expr ) SEMI
const_decl ::= CONST ID [ COLON type ] ASSIGN expr SEMI
function_decl ::= FN ID LPAREN [ param_list ] RPAREN [ ARROW type ] block
extern_fn_decl ::= EXTERN FN ID LPAREN [ param_list ] RPAREN [ ARROW type ] SEMI

param_list ::= param { COMMA param }
param ::= ID COLON type

block ::= LBRACE { statement } RBRACE

statement ::= var_decl
            | const_decl
            | if_stmt
            | while_stmt
            | for_stmt
            | return_stmt
            | print_stmt
            | expr_stmt
            | block

if_stmt ::= IF expr block [ ELSE block ]

while_stmt ::= WHILE expr block

for_stmt ::= FOR ID IN expr block

return_stmt ::= RETURN [ expr ] SEMI

print_stmt ::= ( PRINT | PRINTLN ) expr SEMI

expr_stmt ::= expr SEMI

type ::= base_type
       | VECTOR LESS base_type COMMA INT_LIT GREATER
       | MATRIX LESS base_type COMMA INT_LIT COMMA INT_LIT GREATER
       | TENSOR LESS base_type COMMA INT_LIT COMMA int_list GREATER

int_list ::= INT_LIT { COMMA INT_LIT }

base_type ::= INT | FLOAT | BOOL

expr ::= assign_expr

assign_expr ::= range_expr [ ASSIGN assign_expr ]

range_expr ::= logical_or_expr | RANGE LPAREN expr COMMA expr [ COMMA expr ] RPAREN

logical_or_expr ::= logical_and_expr { OR logical_and_expr }

logical_and_expr ::= bitwise_or_expr { AND bitwise_or_expr }

bitwise_or_expr ::= bitwise_xor_expr { BITWISE_OR bitwise_xor_expr }

bitwise_xor_expr ::= bitwise_and_expr { BITWISE_XOR bitwise_and_expr }

bitwise_and_expr ::= equality_expr { BITWISE_AND equality_expr }

equality_expr ::= relational_expr { ( EQ | NEQ ) relational_expr }

relational_expr ::= additive_expr { ( LESS | LEQ | GREATER | GEQ ) additive_expr }

additive_expr ::= multiplicative_expr { ( PLUS | MINUS ) multiplicative_expr }

multiplicative_expr ::= unary_expr { ( MUL | DIV | DOT_MUL | DOT_DIV ) unary_expr }

unary_expr ::= ( MINUS | NOT | BITWISE_NOT ) unary_expr 
             | postfix_expr

postfix_expr ::= primary_expr { LBRACKET expr_list RBRACKET 
                              | LPAREN [ expr_list ] RPAREN 
                              | DOT ID 
                              | TRANSPOSE }

primary_expr ::= INT_LIT
               | FLOAT_LIT
               | TRUE
               | FALSE
               | ID
               | LPAREN expr RPAREN
               | LBRACKET [ expr_list ] RBRACKET

expr_list ::= expr { COMMA expr }
